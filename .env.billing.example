# Billing Module Environment Variables

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID_STARTER=price_starter_plan_id
STRIPE_PRICE_ID_GROWTH=price_growth_plan_id
STRIPE_PRICE_ID_BUSINESS=price_business_plan_id

# Vinti4 Configuration (Cabo Verde)
VINTI4_API_KEY=your_vinti4_api_key
VINTI4_MERCHANT_ID=your_merchant_id
VINTI4_WEBHOOK_SECRET=your_vinti4_webhook_secret

# Frontend URL
FRONTEND_URL=http://localhost:4200

# Platform Settings
PLATFORM_COMMISSION_PERCENTAGE=20.00
HOLDBACK_DAYS=14
AUTO_APPROVE_THRESHOLD=50.00
