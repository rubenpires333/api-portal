# Database Remoto - Exemplo de configuração
# Substitua com as credenciais do seu banco de dados remoto
SPRING_DATASOURCE_URL=jdbc:postgresql://seu-host-remoto.com:5432/nome_do_banco
SPRING_DATASOURCE_USERNAME=seu_usuario
SPRING_DATASOURCE_PASSWORD=sua_senha_segura

# Keycloak Configuration (do docker-compose.yml)
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=apicv
KEYCLOAK_CLIENT_ID=apicv-backend
KEYCLOAK_CLIENT_SECRET=change-me-in-production
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# Application Configuration
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
FRONTEND_URL=http://localhost:4200

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Stripe Configuration (obtenha em https://dashboard.stripe.com/apikeys)
# IMPORTANTE: Use a chave SECRET (sk_test_...) não a chave PUBLISHABLE (pk_test_...)
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID_STARTER=price_starter
STRIPE_PRICE_ID_GROWTH=price_growth
STRIPE_PRICE_ID_BUSINESS=price_business

# Vinti4 (Cabo Verde) - opcional
VINTI4_API_KEY=
VINTI4_MERCHANT_ID=
VINTI4_WEBHOOK_SECRET=

# Billing Configuration
PLATFORM_COMMISSION_PERCENTAGE=20.00
HOLDBACK_DAYS=14
AUTO_APPROVE_THRESHOLD=50.00

# IMPORTANTE: Copie este arquivo para .env e ajuste os valores conforme necessário
# cp .env.example .env
