# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/db_portal_api
SPRING_DATASOURCE_USERNAME=seu_usuario
SPRING_DATASOURCE_PASSWORD=sua_senha

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=portal-api
KEYCLOAK_CLIENT_ID=portal-api
KEYCLOAK_CLIENT_SECRET=seu_client_secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=sua_senha_admin
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli

# Application Configuration
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
FRONTEND_URL=http://localhost:4200
APP_BASE_URL=http://localhost:8080

# Hibernate Logging (true para ver queries SQL em desenvolvimento, false para produção)
HIBERNATE_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false
HIBERNATE_LOG_LEVEL=ERROR

# Application Logging
LOG_FILE_PATH=logs/application.log
LOG_FILE_MAX_SIZE=10MB
LOG_FILE_MAX_HISTORY=30
LOG_FILE_TOTAL_SIZE=100MB

# Níveis de log por módulo (DEBUG para desenvolvimento, INFO para produção)
APP_LOG_LEVEL=DEBUG
AUTH_LOG_LEVEL=DEBUG
BILLING_LOG_LEVEL=DEBUG
API_LOG_LEVEL=DEBUG

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google reCAPTCHA (opcional)
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=sua_site_key
RECAPTCHA_SECRET_KEY=sua_secret_key

# Email Configuration (opcional)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_email
MAIL_FROM_EMAIL=noreply@apiportal.com
MAIL_FROM_NAME=API Portal

# Stripe Configuration (obtenha em https://dashboard.stripe.com/apikeys)
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID_STARTER=price_starter_id
STRIPE_PRICE_ID_GROWTH=price_growth_id
STRIPE_PRICE_ID_BUSINESS=price_business_id

# Vinti4 (Cabo Verde) - opcional
VINTI4_API_KEY=sua_vinti4_api_key
VINTI4_MERCHANT_ID=seu_merchant_id
VINTI4_WEBHOOK_SECRET=seu_webhook_secret

# Billing Configuration
PLATFORM_COMMISSION_PERCENTAGE=20.00
HOLDBACK_DAYS=14
# Auto-approve threshold (0 = todos levantamentos precisam aprovação manual)
AUTO_APPROVE_THRESHOLD=0.00

# IMPORTANTE: Copie este arquivo para .env e ajuste os valores conforme necessário
# cp .env.example .env
